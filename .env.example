APP_ENV=local
APP_VERSION=2.0.0
DOMAIN_CONTEXT=financial-services
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/maie
CHECKPOINT_DIR=.maie/checkpoints
CHECKPOINT_BACKEND=sqlite
STATE_BACKEND=memory
USE_MOCK_PROVIDERS=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_HOST=https://ollama.com
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_HOST=https://openrouter.ai/api/v1
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
DEMO_HOST=127.0.0.1
DEMO_PORT=8090
KNOWLEDGE_DIR=knowledge/financial-services
ENABLE_GOVERNANCE=true
EVAL_RISK_SCORE_TOLERANCE=15
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=maie-v2
ENABLE_TELEMETRY=true
